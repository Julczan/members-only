<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/styles.css" />
    <title>Document</title>
  </head>
  <body>
    <% if(locals.isAdmin){ %>
    <div>You are an admin</div>
    <% } %>
    <% if (locals.isAuth) {%>
    <h1>
      WELCOME BACK
      <%= currentUser.username %>
    </h1>
    <div>
      <% if(!locals.isMember){ %>
      <div class="member-message">
        <a href="/membership">Become a member</a> to see who's posting
      </div>
      <% } %>
      <a href="/create-message">
        <button>Create new message</button>
      </a>
    </div>
    <a href="/log-out">LOG OUT</a>
    <% } else { %>
    <h1>Welcome to the club</h1>
    <h2>
      please
      <a href="/log-in">log in</a>
      or
      <a href="/sign-up">sign up</a>
      to post some messages
    </h2>
    <%}%>
    <%- include("messageList.ejs") %>
  </body>
</html>
