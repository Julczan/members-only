<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/styles.css" />
    <title>Create Message - Message Board</title>
  </head>
  <body>
    <main class="app-container">
      <div class="form-container">
        <h1 class="form-title">Create New Message</h1>

        <div class="form-errors"><%- include("partials/errors.ejs") %></div>

        <form action="/create-message" method="POST" class="auth-form">
          <div class="form-group">
            <label for="title">Message title</label>
            <input
              id="title"
              name="title"
              placeholder="Give your message a catchy title..."
              type="text"
              required
            />
          </div>

          <div class="form-group">
            <label for="message">Message</label>
            <textarea
              id="message"
              name="message"
              placeholder="What's on your mind?"
              rows="6"
              required
            ></textarea>
          </div>

          <div class="button-group">
            <button type="submit" class="btn-submit">Send</button>
            <a href="/" class="btn-cancel">Cancel</a>
          </div>
        </form>
      </div>
    </main>
  </body>
</html>
