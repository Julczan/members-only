<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/styles.css" />
    <title>Unlock Membership - Message Board</title>
  </head>
  <body>
    <main class="app-container">
      <div class="form-container">
        <h1 class="form-title">Unlock Membership</h1>
        <div class="riddle">To become a member answer:</div>
        <div class="riddle">What can fill a room but takes up no space?</div>
        <div class="form-errors"><%- include("partials/errors.ejs") %></div>

        <form action="/membership" method="post" class="auth-form">
          <div class="form-group">
            <label for="secret">Enter the secret passcode</label>
            <input
              type="password"
              name="secret"
              id="secret"
              placeholder="••••••••"
              required
            />
          </div>

          <div class="button-group">
            <button type="submit" class="btn-submit">Submit</button>
            <a href="/" class="btn-cancel">Cancel</a>
          </div>
        </form>
      </div>
    </main>
  </body>
</html>
